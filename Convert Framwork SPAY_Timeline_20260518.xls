        <Cell ss:StyleID="header"><Data ss:Type="String">%&#10;Complete</Data></Cell>
        <Cell ss:StyleID="header"><Data ss:Type="String">      Start      </Data></Cell>
        <Cell ss:StyleID="header"><Data ss:Type="String">     Finish     </Data></Cell>
        <Cell ss:StyleID="header"><Data ss:Type="String">Estimate&#10;(hours)</Data></Cell>
        <Cell ss:StyleID="header"><Data ss:Type="String">Effort&#10;(hours)</Data></Cell>
        <Cell ss:StyleID="header"><Data ss:Type="String">Chi tiết task / Tiến độ chi tiết</Data></Cell>
      </Row>
      
      <Row ss:AutoFitHeight="1">
        <Cell ss:StyleID="group"><Data ss:Type="String">1</Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String">To Do</Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
      </Row>
      <Row ss:AutoFitHeight="1">
        <Cell ss:StyleID="dataCenter"><Data ss:Type="String">1.1</Data></Cell>
        <Cell ss:StyleID="data"><Data ss:Type="String">implement nạp tiền</Data></Cell>
        <Cell ss:StyleID="dataCenter"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="statusTodo"><Data ss:Type="String">To Do</Data></Cell>
        <Cell ss:StyleID="percent"><Data ss:Type="Number">0</Data></Cell>
        <Cell ss:StyleID="dateStyle"><Data ss:Type="DateTime">2026-05-19T00:00:00.000</Data></Cell>
        <Cell ss:StyleID="dateStyle"><Data ss:Type="DateTime">2026-05-20T00:00:00.000</Data></Cell>
        <Cell ss:StyleID="dataCenter"><Data ss:Type="Number">16</Data></Cell>
        <Cell ss:StyleID="dataCenter"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="data"><Data ss:Type="String">implement nạp tiền</Data></Cell>
      </Row>
      <Row ss:AutoFitHeight="1">
        <Cell ss:StyleID="group"><Data ss:Type="String">2</Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String">In Progress</Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="group"><Data ss:Type="String"></Data></Cell>
      </Row>
      <Row ss:AutoFitHeight="1">

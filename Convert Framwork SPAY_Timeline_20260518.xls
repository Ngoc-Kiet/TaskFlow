        <Cell ss:StyleID="dataCenter"><Data ss:Type="String"></Data></Cell>
        <Cell ss:StyleID="statusInProgress"><Data ss:Type="String">In Progress</Data></Cell>
        <Cell ss:StyleID="percent"><Data ss:Type="Number">0.5</Data></Cell>
        <Cell ss:StyleID="dateStyle"><Data ss:Type="DateTime">2026-05-19T00:00:00.000</Data></Cell>
        <Cell ss:StyleID="dateStyle"><Data ss:Type="DateTime">2026-05-19T00:00:00.000</Data></Cell>
        <Cell ss:StyleID="dataCenter"><Data ss:Type="Number">4</Data></Cell>
